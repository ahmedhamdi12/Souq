@model Souq.ViewModels.Admin.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Admin Dashboard</h1>
        <p class="text-gray-500 text-sm mt-1">
            Platform overview and management
        </p>
    </div>

    <!-- Alert badges for pending items -->
    @if (Model.PendingVendors > 0 || Model.PendingProducts > 0)
    {
        <div class="mb-6 p-4 bg-amber-50 border border-amber-100
                        rounded-xl flex flex-wrap gap-4">
            @if (Model.PendingVendors > 0)
            {
                <a href="/admin/vendors"
                   class="flex items-center gap-2 text-sm text-amber-800
                                  font-medium hover:underline">
                    <span class="w-5 h-5 bg-amber-500 text-white rounded-full
                                         flex items-center justify-center text-xs">
                        @Model.PendingVendors
                    </span>
                    vendor@(Model.PendingVendors != 1 ? "s" : "")
                    awaiting approval
                </a>
            }
            @if (Model.PendingProducts > 0)
            {
                <a href="/admin/products"
                   class="flex items-center gap-2 text-sm text-amber-800
                                  font-medium hover:underline">
                    <span class="w-5 h-5 bg-amber-500 text-white rounded-full
                                         flex items-center justify-center text-xs">
                        @Model.PendingProducts
                    </span>
                    product@(Model.PendingProducts != 1 ? "s" : "")
                    awaiting approval
                </a>
            }
        </div>
    }

    <!-- Stats grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        @foreach (var stat in new[]
                {
                new { Label = "Total users", Value = Model.TotalUsers.ToString(),
                Sub = "Registered accounts",
                Color = "bg-blue-50", TextColor = "text-blue-600",
                Icon = "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" },
                new { Label = "Active vendors", Value = Model.TotalVendors.ToString(),
                Sub = $"{Model.PendingVendors} pending",
                Color = "bg-purple-50", TextColor = "text-purple-600",
                Icon = "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 00-1-1h-2a1 1 0 00-1 1v5m4 0H9" },
                new { Label = "Total products", Value = Model.TotalProducts.ToString(),
                Sub = $"{Model.PendingProducts} pending approval",
                Color = "bg-green-50", TextColor = "text-green-600",
                Icon = "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" },
                new { Label = "Platform earnings", Value = "$" + Model.PlatformEarnings.ToString("0.00"),
                Sub = $"${Model.MonthRevenue:0.00} this month",
                Color = "bg-amber-50", TextColor = "text-amber-600",
                Icon = "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
                })
        {
            <div class="bg-white rounded-2xl border border-gray-100
                            shadow-sm p-5">
                <div class="w-10 h-10 @stat.Color rounded-xl flex items-center
                                justify-center mb-3">
                    <svg class="w-5 h-5 @stat.TextColor" fill="none"
                         stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              stroke-width="1.5" d="@stat.Icon" />
                    </svg>
                </div>
                <p class="text-2xl font-bold text-gray-900">@stat.Value</p>
                <p class="text-sm text-gray-500 mt-0.5">@stat.Label</p>
                <p class="text-xs text-gray-400 mt-1">@stat.Sub</p>
            </div>
        }
    </div>

    <!-- Nav links + Recent activity -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Quick nav -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h2 class="font-bold text-gray-900 mb-4">Management</h2>
            <div class="space-y-2">
                @foreach (var link in new[]
                                {
                                new { Href = "/admin/vendors", Label = "Manage vendors",
                                Color = "bg-purple-100 text-purple-600",
                                Icon = "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 00-1-1h-2a1 1 0 00-1 1v5m4 0H9",
                                Badge = Model.PendingVendors },
                                new { Href = "/admin/products", Label = "Manage products",
                                Color = "bg-green-100 text-green-600",
                                Icon = "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
                                Badge = Model.PendingProducts },
                                })
                {
                    <a href="@link.Href"
                       class="flex items-center justify-between p-3
                                  rounded-xl hover:bg-gray-50 transition-colors">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 @link.Color rounded-lg flex
                                            items-center justify-center">
                                <svg class="w-4 h-4" fill="none"
                                     stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          stroke-width="2" d="@link.Icon" />
                                </svg>
                            </div>
                            <span class="text-sm font-medium text-gray-700">
                                @link.Label
                            </span>
                        </div>
                        @if (link.Badge > 0)
                        {
                            <span class="w-5 h-5 bg-amber-500 text-white
                                                 rounded-full flex items-center
                                                 justify-center text-xs font-bold">
                                @link.Badge
                            </span>
                        }
                    </a>
                }
            </div>
        </div>

        <!-- Recent activity -->
        <div class="lg:col-span-2 bg-white rounded-2xl border border-gray-100
                    shadow-sm p-6">
            <h2 class="font-bold text-gray-900 mb-4">Recent activity</h2>
            @if (!Model.RecentActivity.Any())
            {
                <p class="text-sm text-gray-500 text-center py-8">
                    No recent activity
                </p>
            }
            else
            {
                <div class="space-y-3">
                    @foreach (var item in Model.RecentActivity)
                    {
                        <div class="flex items-center gap-3 p-3
                                            rounded-xl hover:bg-gray-50">
                            <div class="w-8 h-8 @item.Color rounded-lg flex
                                                items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4" fill="none"
                                     stroke="currentColor" viewBox="0 0 24 24">
                                    @if (item.Type == "order")
                                    {
                                        <path stroke-linecap="round"
                                              stroke-linejoin="round"
                                              stroke-width="2"
                                              d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                                    }
                                    else
                                    {
                                        <path stroke-linecap="round"
                                              stroke-linejoin="round"
                                              stroke-width="2"
                                              d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5" />
                                    }
                                </svg>
                            </div>
                            <div class="flex-1">
                                <p class="text-sm font-medium text-gray-900">
                                    @item.Title
                                </p>
                                <p class="text-xs text-gray-500">@item.Subtitle</p>
                            </div>
                            <p class="text-xs text-gray-400">
                                @item.CreatedAt.ToString("MMM dd")
                            </p>
                        </div>
                    }
                </div>
            }
        </div>

        </div>
</div>
