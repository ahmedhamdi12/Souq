@model List<Souq.ViewModels.Admin.AdminProductViewModel>
@{
    ViewData["Title"] = "Manage Products";
}

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Products</h1>
        <p class="text-gray-500 text-sm mt-1">
            @Model.Count total products ·
            @Model.Count(p => !p.IsApproved) pending approval
        </p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-6 p-4 bg-green-50 border border-green-100
                        rounded-xl text-sm text-green-700">
            @TempData["Success"]
        </div>
    }

    <!-- Filter tabs -->
    <div class="flex gap-2 mb-6">
        <a href="/admin/products"
           class="px-4 py-2 text-sm font-medium rounded-xl
                  bg-primary-600 text-white">
            All (@Model.Count)
        </a>
        <a href="/admin/products?filter=pending"
           class="px-4 py-2 text-sm font-medium rounded-xl
                  bg-white border border-gray-200 text-gray-600
                  hover:bg-gray-50 transition-colors">
            Pending (@Model.Count(p => !p.IsApproved))
        </a>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm
                overflow-hidden">

        <div class="grid grid-cols-12 gap-4 px-6 py-3 bg-gray-50
                    border-b border-gray-100 text-xs font-medium
                    text-gray-500 uppercase tracking-wide">
            <div class="col-span-4">Product</div>
            <div class="col-span-2">Vendor</div>
            <div class="col-span-2">Category</div>
            <div class="col-span-1">Price</div>
            <div class="col-span-1">Status</div>
            <div class="col-span-2">Actions</div>
        </div>

        @foreach (var product in Model)
        {
            <div class="grid grid-cols-12 gap-4 px-6 py-4 border-b
                            border-gray-50 items-center last:border-0
                            @(!product.IsApproved ? "bg-amber-50/30" : "")">

                <div class="col-span-4 flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl overflow-hidden
                                    bg-gray-50 flex-shrink-0">
                        @if (product.ImageUrl != null)
                        {
                            <img src="@product.ImageUrl"
                                 alt="@product.Name"
                                 class="w-full h-full object-cover" />
                        }
                    </div>
                    <div>
                        <p class="font-medium text-gray-900 text-sm">
                            @product.Name
                        </p>
                        <p class="text-xs text-gray-400 mt-0.5">
                            @product.CreatedAt.ToString("MMM dd, yyyy")
                        </p>
                    </div>
                </div>

                <div class="col-span-2 text-sm text-gray-600">
                    @product.VendorName
                </div>

                <div class="col-span-2 text-sm text-gray-600">
                    @product.CategoryName
                </div>

                <div class="col-span-1 text-sm font-medium text-gray-900">
                    $@product.BasePrice.ToString("0.00")
                </div>

                <div class="col-span-1">
                    @if (product.IsApproved)
                    {
                        <span class="text-xs bg-green-100 text-green-700
                                             font-medium px-2 py-1 rounded-full">
                            Live
                        </span>
                    }
                    else
                    {
                        <span class="text-xs bg-amber-100 text-amber-700
                                             font-medium px-2 py-1 rounded-full">
                            Pending
                        </span>
                    }
                </div>

                <div class="col-span-2 flex items-center gap-2">
                    @if (!product.IsApproved)
                    {
                        <form asp-controller="Admin"
                              asp-action="ApproveProduct" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId"
                                   value="@product.Id" />
                            <button type="submit"
                                    class="text-xs bg-green-600 hover:bg-green-700
                                                   text-white font-medium px-3 py-1.5
                                                   rounded-lg transition-colors">
                                Approve
                            </button>
                        </form>
                    }

                    <form asp-controller="Admin"
                          asp-action="RejectProduct" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId"
                               value="@product.Id" />
                        <button type="submit"
                                class="text-xs bg-red-100 hover:bg-red-200
                                           text-red-700 font-medium px-3 py-1.5
                                           rounded-lg transition-colors">
                            @(product.IsApproved ? "Unpublish" : "Reject")
                        </button>
                    </form>

                    <a href="/products/@product.Slug"
                       target="_blank"
                       class="text-xs text-gray-400 hover:text-primary-600
                                  transition-colors">
                        View
                    </a>
                </div>
            </div>
        }
    </div>
</div>