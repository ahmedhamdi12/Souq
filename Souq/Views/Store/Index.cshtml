@model Souq.ViewModels.Store.StoreViewModel
@{
    ViewData["Title"] = Model.Vendor.StoreName;
    ViewData["MetaDescription"] = Model.Vendor.Description;
    ViewData["OgTitle"] = Model.Vendor.StoreName + " | Souq";
    ViewData["OgImage"] = Model.Vendor.LogoUrl;
}

<!-- Store Header -->
<div class="bg-gradient-to-r from-primary-600 to-primary-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex flex-col sm:flex-row items-center
                    sm:items-start gap-6">

            <!-- Store logo/avatar -->
            <div class="w-20 h-20 rounded-2xl bg-white flex items-center
                        justify-center shadow-lg flex-shrink-0">
                @if (Model.Vendor.LogoUrl != null)
                {
                    <img src="@Model.Vendor.LogoUrl"
                         alt="@Model.Vendor.StoreName"
                         class="w-full h-full object-cover rounded-2xl" />
                }
                else
                {
                    <span class="text-primary-600 font-bold text-3xl">
                        @Model.Vendor.StoreName.Substring(0, 1)
                    </span>
                }
            </div>

            <!-- Store info -->
            <div class="flex-1 text-center sm:text-left">
                <h1 class="text-2xl font-bold text-white mb-1">
                    @Model.Vendor.StoreName
                </h1>

                @if (Model.Vendor.Description != null)
                {
                    <p class="text-primary-100 text-sm mb-4 max-w-lg">
                        @Model.Vendor.Description
                    </p>
                }

                <!-- Stats row -->
                <div class="flex flex-wrap gap-5 justify-center
                            sm:justify-start">
                    <div class="text-center sm:text-left">
                        <p class="text-2xl font-bold text-white">
                            @Model.TotalProducts
                        </p>
                        <p class="text-xs text-primary-200">Products</p>
                    </div>
                    <div class="text-center sm:text-left">
                        <p class="text-2xl font-bold text-white">
                            @Model.TotalSales
                        </p>
                        <p class="text-xs text-primary-200">Items sold</p>
                    </div>
                    @if (Model.AverageRating > 0)
                    {
                        <div class="text-center sm:text-left">
                            <div class="flex items-center gap-1">
                                <p class="text-2xl font-bold text-white">
                                    @Model.AverageRating
                                </p>
                                <svg class="w-5 h-5 text-amber-400"
                                     fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                            </div>
                            <p class="text-xs text-primary-200">
                                @Model.TotalReviews review@(Model.TotalReviews != 1 ? "s" : "")
                            </p>
                        </div>
                    }
                    <div class="text-center sm:text-left">
                        <p class="text-2xl font-bold text-white">
                            @Model.Vendor.CreatedAt.ToString("MMM yyyy")
                        </p>
                        <p class="text-xs text-primary-200">Member since</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Products -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900">
            All products
            <span class="text-gray-400 font-normal ml-1 text-base">
                (@Model.TotalProducts)
            </span>
        </h2>
    </div>

    @if (!Model.Products.Any())
    {
        <div class="text-center py-20 bg-white rounded-2xl
                    border border-gray-100">
            <p class="text-gray-500">No products available yet.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3
                    xl:grid-cols-4 gap-5">
            @foreach (var product in Model.Products)
            {
                
                    var mainImage = product.Images
                        .FirstOrDefault(i => i.IsMain)?.ImageUrl
                        ?? product.Images.FirstOrDefault()?.ImageUrl;

                    var displayPrice = product.HasVariations
                        && product.Variations.Any()
                        ? product.Variations.Min(v => v.Price)
                        : product.BasePrice;

                    var avgRating = product.Reviews.Any()
                        ? product.Reviews.Average(r => r.Rating)
                        : 0;
                

                <div class="group bg-white rounded-2xl border
                            border-gray-100 shadow-sm hover:shadow-lg
                            transition-all duration-300 overflow-hidden
                            hover:-translate-y-1 flex flex-col">

                    <a href="/products/@product.Slug" class="block">
                        <div class="relative aspect-square bg-gray-50
                                    overflow-hidden">
                            @if (mainImage != null)
                            {
                                <img src="@mainImage"
                                     alt="@product.Name"
                                     loading="lazy"
                                     class="w-full h-full object-cover
                                            group-hover:scale-105
                                            transition-transform duration-500"/>
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center
                                            justify-center bg-gray-100">
                                    <svg class="w-12 h-12 text-gray-300"
                                         fill="none" stroke="currentColor"
                                         viewBox="0 0 24 24">
                                        <path stroke-linecap="round"
                                              stroke-linejoin="round"
                                              stroke-width="1"
                                              d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                </div>
                            }
                        </div>
                    </a>

                    <div class="p-4 flex flex-col flex-1">
                        <a href="/products/@product.Slug">
                            <h3 class="font-medium text-gray-900 text-sm
                                       line-clamp-2 mb-1
                                       group-hover:text-primary-600
                                       transition-colors">
                                @product.Name
                            </h3>
                        </a>

                        @if (avgRating > 0)
                        {
                            <div class="flex items-center gap-1 mb-1">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <svg class="w-3 h-3 @(i <= avgRating
                                        ? "text-amber-400"
                                        : "text-gray-200")"
                                         fill="currentColor"
                                         viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                    </svg>
                                }
                                <span class="text-xs text-gray-400">
                                    (@product.Reviews.Count)
                                </span>
                            </div>
                        }

                        <div class="flex items-center justify-between mt-auto pt-3">
                            <p class="text-base font-bold text-gray-900">
                                @if (product.HasVariations
                                    && product.Variations.Any())
                                {
                                    <span class="text-xs font-normal
                                                 text-gray-500 mr-0.5">
                                        From
                                    </span>
                                }
                                $@displayPrice.ToString("0.00")
                            </p>
                            <a href="/products/@product.Slug"
                               class="w-8 h-8 flex items-center justify-center
                                      bg-primary-600 text-white rounded-lg
                                      hover:bg-primary-700 transition-colors">
                                <svg class="w-4 h-4" fill="none"
                                     stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          stroke-width="2" d="M12 4v16m8-8H4"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>