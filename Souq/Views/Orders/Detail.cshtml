@model Souq.ViewModels.Orders.OrderDetailViewModel
@{
    ViewData["Title"] = "Order" + Model.OrderNumber;
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Header -->
    <div class="flex items-center gap-4 mb-8">
        <a href="/orders"
           class="p-2 rounded-lg hover:bg-gray-100 transition-colors">
            <svg class="w-5 h-5 text-gray-600" fill="none"
                 stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                      stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-gray-900">
                Order @Model.OrderNumber
            </h1>
            <div class="flex items-center gap-2 mt-1">
                <p class="text-sm text-gray-500">
                    Placed @Model.CreatedAt.ToString("MMMM dd, yyyy")
                </p>
                <span class="text-xs font-medium px-2.5 py-1
                             rounded-full @Model.StatusColor">
                    @Model.Status
                </span>
            </div>
        </div>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- ── Left: Items + Shipping ── -->
        <div class="lg:col-span-2 space-y-5">
            <!-- Items -->
            <div class="bg-white rounded-2xl border border-gray-100
                        shadow-sm p-6">
                <h2 class="font-bold text-gray-900 mb-5">Items ordered</h2>
                <div class="space-y-4">
                    @foreach (var item in Model.Items)
                    {
                        <div class="flex gap-4 items-start pb-4
                                        border-b border-gray-100 last:border-0
                                        last:pb-0">
                            <div class="w-16 h-16 rounded-xl overflow-hidden
                                            bg-gray-50 flex-shrink-0">
                                @if (item.ImageUrl != null)
                                {
                                    <img src="@item.ImageUrl"
                                         alt="@item.ProductName"
                                         class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    <div class="w-full h-full flex items-center
                                                        justify-center">
                                        <svg class="w-6 h-6 text-gray-300"
                                             fill="none" stroke="currentColor"
                                             viewBox="0 0 24 24">
                                            <path stroke-linecap="round"
                                                  stroke-linejoin="round"
                                                  stroke-width="1"
                                                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                    </div>
                                }
                            </div>
                            <div class="flex-1">
                                <p class="font-medium text-gray-900 text-sm">
                                    @item.ProductName
                                </p>
                                <p class="text-xs text-gray-500 mt-0.5">
                                    @item.VariationName
                                    · by @item.VendorName
                                </p>
                                <p class="text-xs text-gray-500 mt-0.5">
                                    Qty: @item.Quantity
                                    × $@item.UnitPrice.ToString("0.00")
                                </p>
                            </div>
                            <p class="font-bold text-gray-900 text-sm
                                          flex-shrink-0">
                                $@item.LineTotal.ToString("0.00")
                            </p>
                        </div>
                    }
                </div>
            </div>
            <!-- Shipping -->
            <div class="bg-white rounded-2xl border border-gray-100
                        shadow-sm p-6">
                <h2 class="font-bold text-gray-900 mb-4">
                    Shipping address
                </h2>
                <div class="text-sm text-gray-600 space-y-1">
                    <p class="font-medium text-gray-900">
                        @Model.ShippingFullName
                    </p>
                    <p>@Model.ShippingAddress</p>
                    <p>@Model.ShippingCity, @Model.ShippingCountry</p>
                    <p>@Model.ShippingPhone</p>
                </div>
            </div>
        </div>
        <!-- ── Right: Summary ── -->
        <div class="lg:col-span-1">
            <div class="bg-white rounded-2xl border border-gray-100
                        shadow-sm p-6 sticky top-24">

                <h2 class="font-bold text-gray-900 mb-4">Order summary</h2>

                <div class="space-y-2 text-sm">
                    <div class="flex justify-between text-gray-600">
                        <span>Subtotal</span>
                        <span>$@Model.SubTotal.ToString("0.00")</span>
                    </div>
                    <div class="flex justify-between text-gray-600">
                        <span>Shipping</span>
                        <span class="text-green-600">Free</span>
                    </div>
                    <div class="flex justify-between font-bold text-gray-900
                                pt-3 border-t border-gray-100">
                        <span>Total</span>
                        <span>$@Model.Total.ToString("0.00")</span>
                    </div>
                </div>

                @if (Model.PaidAt.HasValue)
                {
                    <div class="mt-4 pt-4 border-t border-gray-100">
                        <p class="text-xs text-gray-500">
                            Paid on @Model.PaidAt.Value.ToString("MMM dd, yyyy 'at' h:mm tt")
                        </p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

