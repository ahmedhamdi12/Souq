@model Souq.ViewModels.Products.ProductDetailViewModel
@{
    ViewData["Title"] = Model.Product.MetaTitle ?? Model.Product.Name;

    ViewData["MetaDescription"] = Model.Product.MetaDescription
        ?? Model.Product.Description?.Substring(0,
            Math.Min(160, Model.Product.Description?.Length ?? 0));

    ViewData["OgTitle"] = Model.Product.Name + " | Souq";
    ViewData["OgDescription"] = Model.Product.MetaDescription
        ?? Model.Product.Description?.Substring(0,
            Math.Min(160, Model.Product.Description?.Length ?? 0));

    ViewData["OgType"] = "product";
    ViewData["OgImage"] = Model.AllImages.FirstOrDefault();
    ViewData["CanonicalUrl"] = $"https://souq.com/products/{Model.Product.Slug}";

    ViewData["MetaKeywords"] = $"{Model.Product.Name}, "
        + $"{Model.Product.Category.Name}, "
        + $"{Model.Product.Category.Department.Name}, "
        + "buy online, Souq";
}

@* SEO Meta Tags *@
@section Styles {
    <meta name="description"
          content="@(Model.Product.MetaDescription ?? Model.Product.Description)"/>
    <meta property="og:title" content="@Model.Product.Name"/>
    <meta property="og:description"
          content="@(Model.Product.MetaDescription ?? Model.Product.Description)"/>
    @if (Model.AllImages.Any())
    {
        <meta property="og:image" content="@Model.AllImages.First()"/>
    }
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
        <a href="/" class="hover:text-primary-600 transition-colors">Home</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <a href="/products" class="hover:text-primary-600 transition-colors">
            Products
        </a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <a href="/products/department/@Model.Product.Category.Department.Slug"
           class="hover:text-primary-600 transition-colors">
            @Model.Product.Category.Department.Name
        </a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-gray-900 font-medium truncate max-w-xs">
            @Model.Product.Name
        </span>
    </nav>

    <!-- Main product section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- ══ LEFT: Image Gallery ══ -->
        <div x-data="imageGallery()"
        x-on:color-selected.window="switchToColor($event.detail.color)"
        class="space-y-4">

            <!-- Main image -->
            <div class="aspect-square bg-gray-50 rounded-2xl overflow-hidden
                        border border-gray-100">
                <img :src="activeImage"
                     alt="@Model.Product.Name"
                     class="w-full h-full object-cover transition-opacity
                            duration-300"/>
            </div>

            <!-- Thumbnails -->
            @if (Model.AllImages.Count > 1)
            {
                <div class="flex gap-3 overflow-x-auto pb-1">
                    @foreach (var img in Model.AllImages)
                    {
                        <button @@click="setImage('@img')"
                                class="flex-shrink-0 w-16 h-16 rounded-xl
                                       overflow-hidden border-2 transition-all"
                                :class="activeImage === '@img'
                                    ? 'border-primary-500'
                                    : 'border-gray-100 hover:border-gray-300'">
                            <img src="@img" alt="thumbnail"
                                 class="w-full h-full object-cover"/>
                        </button>
                    }
                </div>
            }
        </div>

        <!-- ══ RIGHT: Product Info ══ -->
        <div x-data="productConfig()" class="space-y-6">

            <!-- Vendor link -->
            <a href="/store/@Model.Product.Vendor.StoreSlug"
               class="inline-flex items-center gap-2 text-sm text-gray-500
                      hover:text-primary-600 transition-colors">
                <div class="w-6 h-6 bg-primary-100 rounded-full flex items-center
                            justify-center">
                    <span class="text-primary-700 text-xs font-bold">
                        @Model.Product.Vendor.StoreName.Substring(0, 1)
                    </span>
                </div>
                @Model.Product.Vendor.StoreName
            </a>

            <!-- Product name -->
            <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 leading-tight">
                @Model.Product.Name
            </h1>

            <!-- Rating row -->
            @if (Model.Product.Reviews.Any())
            {
                var avgRating = Model.Product.Reviews.Average(r => r.Rating);
                var reviewCount = Model.Product.Reviews.Count;
                <div class="flex items-center gap-2">
                    <div class="flex items-center gap-0.5">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <svg class="w-4 h-4 @(i <= avgRating
                                ? "text-amber-400" : "text-gray-200")"
                                 fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                            </svg>
                        }
                    </div>
                    <span class="text-sm text-gray-500">
                        @avgRating.ToString("0.0")
                        (@reviewCount review@(reviewCount != 1 ? "s" : ""))
                    </span>
                </div>
            }

            <!-- Price -->
            <div class="py-4 border-y border-gray-100">
                <p class="text-3xl font-bold text-gray-900">
                    @if (Model.HasPriceRange)
                    {
                        <span class="text-base font-normal text-gray-500 mr-1">
                            From
                        </span>
                    }
                    <span x-text="'$' + selectedPrice">
                        $@Model.MinPrice.ToString("0.00")
                    </span>
                </p>
            </div>

            <!-- Color variations -->
            @if (Model.VariationsByColor.Any(kv => kv.Key != string.Empty))
            {
                <div>
                    <p class="text-sm font-medium text-gray-700 mb-3">
                        Color:
                        <span x-text="selectedColor"
                              class="text-gray-900 font-semibold">
                        </span>
                    </p>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var colorGroup in Model.VariationsByColor
                            .Where(kv => kv.Key != string.Empty))
                        {
                            var firstVar = colorGroup.Value.First();
                            <button @@click="selectColor('@colorGroup.Key',
                                            @firstVar.Id,
                                            @firstVar.Price)"
                                    class="px-4 py-2 rounded-xl text-sm font-medium
                                           border-2 transition-all"
                                    :class="selectedColor === '@colorGroup.Key'
                                        ? 'border-primary-500 bg-primary-50 text-primary-700'
                                        : 'border-gray-200 text-gray-700 hover:border-gray-300'">
                                @colorGroup.Key
                            </button>
                        }
                    </div>
                </div>
            }

            <!-- Size variations -->
            @if (Model.Product.Variations.Any(v => v.Size != null))
            {
                <div>
                    <p class="text-sm font-medium text-gray-700 mb-3">Size:</p>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var variation in Model.Product.Variations
                            .Where(v => v.Size != null)
                            .DistinctBy(v => v.Size))
                        {
                            <button @@click="selectVariation(@variation.Id,
                                            @variation.Price)"
                                    class="px-4 py-2 rounded-xl text-sm font-medium
                                           border-2 transition-all"
                                    :class="selectedVariationId === @variation.Id
                                        ? 'border-primary-500 bg-primary-50 text-primary-700'
                                        : 'border-gray-200 text-gray-700 hover:border-gray-300'">
                                @variation.Size
                            </button>
                        }
                    </div>
                </div>
            }

            <!-- No variations — just base price product -->
            @if (!Model.Product.HasVariations)
            {
                <input type="hidden" id="direct-variation-id"
                       value="@Model.Product.Variations.FirstOrDefault()?.Id"/>
            }

            <!-- Stock indicator -->
            <div>
                <p x-show="selectedVariationId === 0"
                   class="text-sm text-gray-400">
                    Select an option to see availability
                </p>
                <p x-show="selectedVariationId > 0"
                   :class="selectedStock > 10 ? 'text-sm text-green-600' : selectedStock > 0
                    ? 'text-sm text-amber-600'
                    : 'text-sm text-red-600'">
                    <span x-text="selectedStock >   10   ? 'In stock'   : selectedStock > 0
                        ? 'Only ' + selectedStock + ' left'
                        : 'Out of stock'">
                    </span>
                </p>
            </div>

            <!-- Quantity selector + Add to cart -->
            <div class="flex items-center gap-4">

                <!-- Quantity -->
                <div class="flex items-center border border-gray-200
                            rounded-xl overflow-hidden">
                    <button @@click="qty > 1 ? qty-- : null"
                            class="px-4 py-3 text-gray-600 hover:bg-gray-50
                                   transition-colors text-lg font-medium">
                        −
                    </button>
                    <span x-text="qty"
                          class="px-4 py-3 text-sm font-semibold text-gray-900
                                 min-w-12 text-center border-x border-gray-200">
                        1
                    </span>
                    <button @@click="qty < selectedStock ? qty++ : null"
                            class="px-4 py-3 text-gray-600 hover:bg-gray-50
                                   transition-colors text-lg font-medium">
                        +
                    </button>
                </div>

                <!-- Add to cart -->
                <button @@click="addToCart()"
                        :disabled="selectedVariationId === 0 || selectedStock === 0 || loading"
                        class="flex-1 flex items-center justify-center gap-2
                               bg-primary-600 hover:bg-primary-700
                               disabled:bg-gray-300 disabled:cursor-not-allowed
                               text-white font-semibold py-3 rounded-xl
                               transition-all shadow-lg hover:-translate-y-0.5
                               active:translate-y-0">
                    <!-- Loading spinner -->
                    <svg x-show="loading"
                         class="w-5 h-5 animate-spin"
                         fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10"
                                stroke="currentColor" stroke-width="4" />
                        <path class="opacity-75" fill="currentColor"
                              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
                    </svg>

                    <svg x-show="!loading" class="w-5 h-5" fill="none"
                         stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              stroke-width="2"
                              d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                    </svg>

                    <span x-text="loading ? 'Adding...'
                                    : selectedVariationId === 0 ? 'Select an option'
                                    : selectedStock === 0 ? 'Out of stock'
                                    : 'Add to cart'">
                    </span>
                    
                </button>
            </div>

            <!-- Success message -->
            <div x-show="addedToCart"
                 x-transition
                 class="flex items-center gap-2 text-green-600 text-sm
                        bg-green-50 px-4 py-3 rounded-xl border border-green-100">
                <svg class="w-4 h-4" fill="none" stroke="currentColor"
                     viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Added to cart successfully!
            </div>

            <!-- Description -->
            <div class="prose prose-sm text-gray-600 leading-relaxed">
                <p>@Model.Product.Description</p>
            </div>

        </div>
    </div>

    <!-- ══ Reviews Section ══ -->
    @if (Model.Product.Reviews.Any())
    {
        <section class="mt-16 pt-10 border-t border-gray-100">
            <h2 class="text-xl font-bold text-gray-900 mb-6">
                Customer reviews
                <span class="text-gray-400 font-normal text-base ml-2">
                    (@Model.Product.Reviews.Count)
                </span>
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                @foreach (var review in Model.Product.Reviews
                    .OrderByDescending(r => r.CreatedAt).Take(6))
                {
                    <div class="bg-white rounded-2xl border border-gray-100
                                shadow-sm p-5">
                        <div class="flex items-center justify-between mb-3">
                            <div class="flex items-center gap-2">
                                <div class="w-8 h-8 bg-primary-100 rounded-full
                                            flex items-center justify-center">
                                    <span class="text-primary-700 text-xs font-bold">
                                        @review.User.FirstName.Substring(0,1)
                                    </span>
                                </div>
                                <span class="text-sm font-medium text-gray-900">
                                    @review.User.FirstName @review.User.LastName
                                </span>
                            </div>
                            <div class="flex items-center gap-0.5">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <svg class="w-3.5 h-3.5 @(i <= review.Rating
                                        ? "text-amber-400" : "text-gray-200")"
                                         fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                    </svg>
                                }
                            </div>
                        </div>
                        @if (review.Comment != null)
                        {
                            <p class="text-sm text-gray-600 leading-relaxed">
                                @review.Comment
                            </p>
                        }
                        <p class="text-xs text-gray-400 mt-2">
                            @review.CreatedAt.ToString("MMM dd, yyyy")
                        </p>
                    </div>
                }
            </div>
        </section>
    }

    <!-- ══ Add Review Form ══ -->
    @{
        var canReview = (bool)(ViewData["CanReview"] ?? false);
    }

    @if (TempData["ReviewSuccess"] != null)
    {
        <div class="mt-6 p-4 bg-green-50 border border-green-100
                    rounded-xl text-sm text-green-700">
            @TempData["ReviewSuccess"]
        </div>
    }

    @if (TempData["ReviewError"] != null)
    {
        <div class="mt-6 p-4 bg-red-50 border border-red-100
                    rounded-xl text-sm text-red-600">
            @TempData["ReviewError"]
        </div>
    }

    @if (canReview)
    {
        <div class="mt-8 bg-white rounded-2xl border border-gray-100
                    shadow-sm p-6">
            <h3 class="font-bold text-gray-900 mb-4">
                Write a review
            </h3>

            <form asp-controller="Products" asp-action="AddReview"
                  method="post" class="space-y-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ProductId"
                       value="@Model.Product.Id" />
                <input type="hidden" name="ProductSlug"
                       value="@Model.Product.Slug" />

                <!-- Star rating -->
                <div x-data="{ rating: 0, hover: 0 }">
                    <p class="text-sm font-medium text-gray-700 mb-2">
                        Your rating
                    </p>
                    <div class="flex gap-1 mb-1">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <button type="button"
                                    @@click="rating = @i"
                                    @@mouseover="hover = @i"
                                    @@mouseleave="hover = 0"
                                    class="transition-transform hover:scale-110">
                                <svg class="w-8 h-8 transition-colors"
                                     :class="(@i <= (hover || rating))
                                             ? 'text-amber-400'
                                             : 'text-gray-200'"
                                     fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                            </button>
                        }
                    </div>
                    <input type="hidden" name="Rating" :value="rating" />
                </div>

                <!-- Comment -->
                <div>
                    <label class="block text-sm font-medium
                                  text-gray-700 mb-1.5">
                        Comment
                        <span class="text-gray-400 font-normal">(optional)</span>
                    </label>
                    <textarea name="Comment" rows="3"
                          placeholder="Share your experience..."
                          class="w-full px-4 py-2.5 border border-gray-200
                                 rounded-xl text-sm focus:outline-none
                                 focus:ring-2 focus:ring-primary-500
                                 focus:border-transparent transition-all
                                 resize-none"></textarea>
                </div>

                <button type="submit"
                        class="bg-primary-600 hover:bg-primary-700
                               text-white font-medium px-6 py-2.5
                               rounded-xl transition-colors text-sm">
                    Submit review
                </button>
            </form>
        </div>
    }
    else if (User.Identity!.IsAuthenticated && !canReview)
    {
        /*
        User is logged in but can't review.
        Either hasn't bought it or already reviewed.
        Show a subtle message.
        */
        <div class="mt-6 p-4 bg-gray-50 border border-gray-100
                    rounded-xl text-sm text-gray-500">
            Only customers who have purchased and received
            this product can leave a review.
        </div>
    }
    else
    {
        <!-- Not logged in -->
        <div class="mt-6 p-4 bg-gray-50 border border-gray-100
                    rounded-xl text-sm text-gray-500">
            <a href="/account/login"
               class="text-primary-600 hover:underline font-medium">
                Sign in
            </a>
            to leave a review.
        </div>
    }
   <!-- ══ Related Products ══ -->
    @if (Model.RelatedProducts.Any())
    {
        <section class="mt-16 pt-10 border-t border-gray-100">
            <h2 class="text-xl font-bold text-gray-900 mb-6">
                You might also like
            </h2>
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
                @foreach (var related in Model.RelatedProducts)
                {
                    var relatedImage = related.Images
                        .FirstOrDefault(i => i.IsMain)?.ImageUrl
                        ?? related.Images.FirstOrDefault()?.ImageUrl;

                    <a href="/products/@related.Slug"
                       class="group bg-white rounded-2xl border border-gray-100
                              shadow-sm overflow-hidden hover:shadow-md
                              hover:-translate-y-1 transition-all duration-300">
                        <div class="aspect-square bg-gray-50 overflow-hidden">
                            @if (relatedImage != null)
                            {
                                <img src="@relatedImage" alt="@related.Name"
                                     class="w-full h-full object-cover
                                            group-hover:scale-105 transition-transform
                                            duration-500"/>
                            }
                        </div>
                        <div class="p-3">
                            <p class="text-sm font-medium text-gray-900
                                      line-clamp-2 group-hover:text-primary-600
                                      transition-colors">
                                @related.Name
                            </p>
                            <p class="text-sm font-bold text-gray-900 mt-1">
                                $@(related.HasVariations && related.Variations.Any()
                                    ? related.Variations.Min(v => v.Price)
                                            .ToString("0.00")
                                    : related.BasePrice.ToString("0.00"))
                            </p>
                        </div>
                    </a>
                }
            </div>
        </section>
    }

</div>
@section Scripts {
    <script>
        
        const variations = @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(
                        Model.Product.Variations.ToDictionary(
                                v => v.Id,
                                v => new
                                {
                                        id = v.Id,
                                        price = v.Price,
                                        stock = v.AvailableStock,
                                        color = v.Color ?? "",
                                        size = v.Size ?? "",
                                        image = v.ImageUrl ?? ""
                                }
                        )
                )
        );

        const imagesByColor = @Html.Raw(
                    System.Text.Json.JsonSerializer.Serialize(
                            Model.ImagesByColor
                    )
            );

    const allImages = @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(
                        Model.AllImages
                )
        );

    /*
        Alpine.js component for the image gallery.
        activeImage = currently displayed large image.
        setImage()  = called by thumbnail clicks.
    */
    function imageGallery() {
        return {
            activeImage: allImages[0] ?? '',

                setImage(url) {
                    this.activeImage = url;
                },

                switchToColor(color) {
                    /*
                        When user picks a color, find images
                        for that color. Fall back to all images
                        if no color-specific images exist.
                    */
                    const imgs = imagesByColor[color] || allImages;
                    if (imgs.length > 0) this.activeImage = imgs[0];
                }
            }
        }

        /*
            Alpine.js component for product configuration.
            Manages: color selection, size selection,
            quantity control, and add to cart.
        */
        function productConfig() {
            return {
                selectedVariationId: 0,
                selectedColor:       '',
                selectedPrice:       '@Model.MinPrice.ToString("0.00")',
                selectedStock:       0,
                qty:                 1,
                addedToCart:         false,
                loading:             false,

                /*
                    selectColor is called when user clicks a color button.
                    It updates:
                    - selectedColor (for button active state)
                    - selectedVariationId (which variation to add to cart)
                    - selectedPrice (shown in price display)
                    - selectedStock (for stock indicator + qty limit)
                    Then dispatches event to gallery to switch images.
                */
                selectColor(color, variationId, price) {
                    this.selectedColor       = color;
                    this.selectedVariationId = variationId;
                    this.selectedPrice       = parseFloat(price).toFixed(2);
                    this.selectedStock       = variations[variationId]?.stock ?? 0;
                    this.qty                 = 1;

                    /*
                        $dispatch sends a custom Alpine event.
                        The imageGallery component listens for
                        'color-selected' via x-on:color-selected.window
                        We'll wire this up in the HTML.
                    */
                    this.$dispatch('color-selected', { color });
                },

                /*
                    selectVariation is called for size/other variations
                    that don't have a color (no image switch needed).
                */
                selectVariation(variationId, price) {
                    this.selectedVariationId = variationId;
                    this.selectedPrice       = parseFloat(price).toFixed(2);
                    this.selectedStock       = variations[variationId]?.stock ?? 0;
                    this.qty                 = 1;
                },

                async addToCart() {
                    if (this.selectedVariationId === 0 || this.selectedStock === 0)
                        return;

                     this.loading = true;

                    try {
                        const res = await fetch('/cart/add', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': document
                                    .querySelector(
                                        'input[name="__RequestVerificationToken"]'
                                    )?.value ?? ''
                            },
                            body: JSON.stringify({
                                variationId: this.selectedVariationId,
                                quantity:    this.qty
                            })
                        });

                        if (!res.ok) throw new Error('Request failed');

                        const data = await res.json();

                        if (data.success) {
                            // Update navbar badge
                            const badge = document.getElementById('cart-count');
                            if (badge) {
                                badge.textContent = data.cartCount;
                                badge.classList.remove('hidden');
                            }
                             showToast('Added to cart successfully!');
                            // Show success message then hide after 2s
                            this.addedToCart = true;
                            setTimeout(() => this.addedToCart = false, 2000);
                        }
                    } catch (err) {
                        console.error('Add to cart failed:', err);
                    }
                    finally
                    {
                            this.loading = false;  // ← hide spinner always
                    }
                }
            }
        }
    </script>

    <form id="af-form">@Html.AntiForgeryToken()</form>
}