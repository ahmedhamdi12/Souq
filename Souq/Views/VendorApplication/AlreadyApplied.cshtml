@{
    ViewData["Title"] = "Application Pending";
}

<div class="max-w-lg mx-auto px-4 py-20 text-center">

    <div class="w-20 h-20 bg-amber-100 rounded-full flex items-center
                justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-amber-500" fill="none"
             stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
    </div>

    <h1 class="text-2xl font-bold text-gray-900 mb-3">
        Application under review
    </h1>
    <p class="text-gray-500 mb-8">
        You've already submitted a vendor application.
        Our team is reviewing it and will notify you once
        a decision has been made.
    </p>

    <a href="/"
       class="inline-flex items-center gap-2 bg-primary-600
              hover:bg-primary-700 text-white font-semibold
              px-8 py-3 rounded-xl transition-all">
        Back to home
    </a>
</div>