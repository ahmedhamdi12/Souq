@model Souq.ViewModels.Vendor.VendorApplicationViewModel
@{
    ViewData["Title"] = "Become a Vendor";
}

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Header -->
    <div class="text-center mb-10">
        <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center
                    justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary-600" fill="none"
                 stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 00-1-1h-2a1 1 0 00-1 1v5m4 0H9" />
            </svg>
        </div>
        <h1 class="text-3xl font-bold text-gray-900">
            Start selling on Souq
        </h1>
        <p class="text-gray-500 mt-2 max-w-md mx-auto">
            Join hundreds of vendors already growing their business.
            Fill in your store details and we'll review your application.
        </p>
    </div>

    <!-- Benefits -->
    <div class="grid grid-cols-3 gap-4 mb-10">
        @foreach (var benefit in new[]
                {
                new { Icon = "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
                Title = "Keep 90%", Sub = "of every sale" },
                new { Icon = "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
                Title = "10,000+", Sub = "customers" },
                new { Icon = "M13 10V3L4 14h7v7l9-11h-7z",
                Title = "Fast setup", Sub = "minutes to start" }
                })
        {
            <div class="bg-white rounded-2xl border border-gray-100
                            shadow-sm p-4 text-center">
                <svg class="w-6 h-6 text-primary-600 mx-auto mb-2"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          stroke-width="1.5" d="@benefit.Icon" />
                </svg>
                <p class="font-bold text-gray-900 text-sm">@benefit.Title</p>
                <p class="text-xs text-gray-500">@benefit.Sub</p>
            </div>
        }
    </div>

    <!-- Application Form -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">

        <h2 class="font-bold text-gray-900 text-lg mb-6">
            Your store details
        </h2>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mb-5 p-4 bg-red-50 border border-red-100 rounded-xl">
                @foreach (var error in ViewData.ModelState.Values
                            .SelectMany(v => v.Errors))
                {
                    <p class="text-sm text-red-600">@error.ErrorMessage</p>
                }
            </div>
        }

        <form asp-controller="VendorApplication" asp-action="Apply"
              method="post" enctype="multipart/form-data" class="space-y-5">
            @Html.AntiForgeryToken()

            <!-- Store name -->
            <div>
                <label asp-for="StoreName"
                       class="block text-sm font-medium text-gray-700 mb-1.5">
                    Store name
                </label>
                <input asp-for="StoreName"
                       placeholder="e.g. Tech Haven, Fashion Studio..."
                       class="w-full px-4 py-2.5 border border-gray-200
                              rounded-xl text-sm focus:outline-none
                              focus:ring-2 focus:ring-primary-500
                              focus:border-transparent transition-all" />
                <span asp-validation-for="StoreName"
                      class="text-xs text-red-500 mt-1"></span>
                <p class="text-xs text-gray-400 mt-1">
                    This will be your public store name on Souq
                </p>
            </div>

            <!-- Description -->
            <div>
                <label asp-for="Description"
                       class="block text-sm font-medium text-gray-700 mb-1.5">
                    What do you sell?
                </label>
                <textarea asp-for="Description" rows="4"
                          placeholder="Describe your store and products..."
                          class="w-full px-4 py-2.5 border border-gray-200
                                 rounded-xl text-sm focus:outline-none
                                 focus:ring-2 focus:ring-primary-500
                                 focus:border-transparent transition-all
                                 resize-none"></textarea>
                <span asp-validation-for="Description"
                      class="text-xs text-red-500 mt-1"></span>
            </div>

            <!-- Phone -->
            <div>
                <label asp-for="Phone"
                       class="block text-sm font-medium text-gray-700 mb-1.5">
                    Business phone
                    <span class="text-gray-400 font-normal">(optional)</span>
                </label>
                <input asp-for="Phone"
                       placeholder="+20 1234 567 8900"
                       class="w-full px-4 py-2.5 border border-gray-200
                              rounded-xl text-sm focus:outline-none
                              focus:ring-2 focus:ring-primary-500
                              focus:border-transparent transition-all" />
                <span asp-validation-for="Phone"
                      class="text-xs text-red-500 mt-1"></span>
            </div>

            <!--logo-->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">
                    Store logo
                    <span class="text-gray-400 font-normal">(optional)</span>
                </label>
                <input type="file" name="LogoFile" accept="image/*"
                       class="text-sm text-gray-500 file:mr-3 file:py-2 file:px-4
                  file:rounded-xl file:border-0 file:text-sm file:font-medium
                  file:bg-primary-50 file:text-primary-700
                  hover:file:bg-primary-100 cursor-pointer" />
                <p class="text-xs text-gray-400 mt-1">
                    PNG, JPG up to 2MB. Shown on your store page.
                </p>
            </div>

            <!-- Submit -->
            <button type="submit"
                    class="w-full bg-primary-600 hover:bg-primary-700
                           text-white font-semibold py-3 rounded-xl
                           transition-all shadow-lg hover:-translate-y-0.5
                           active:translate-y-0 mt-2">
                Submit application
            </button>
        </form>
    </div>

    <p class="text-center text-xs text-gray-400 mt-5">
        By applying you agree to our vendor terms of service.
        Applications are reviewed within 1-2 business days.
    </p>
</div>

