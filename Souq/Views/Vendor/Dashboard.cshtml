@model Souq.ViewModels.Vendor.VendorDashboardViewModel 
@{
    ViewData["Title"] = "Vendor Dashboard";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">
                @Model.StoreName
            </h1>
            <p class="text-gray-500 text-sm mt-1">Vendor Dashboard</p>
        </div>
        <a href="/vendor/products/create"
           class="inline-flex items-center gap-2 bg-primary-600
                  hover:bg-primary-700 text-white font-medium px-4 py-2.5
                  rounded-xl transition-colors text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor"
                 viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                      stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Add product
        </a>
    </div>
    <!-- Success message -->
    @if (TempData["Success"] != null)
    {
        <div class="mb-6 p-4 bg-green-50 border border-green-100
                        rounded-xl text-sm text-green-700 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor"
                 viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                      stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            @TempData["Success"]
        </div>
    }

    <!-- Stats grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">

        @foreach (var stat in new[]
                {
                new { Label = "Total products", Value = Model.TotalProducts.ToString(),
                Sub = $"{Model.PendingApproval} pending approval",
                Color = "bg-blue-50", Icon = "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
                TextColor = "text-blue-600" },
                new { Label = "Total orders", Value = Model.TotalOrders.ToString(),
                Sub = $"{Model.PendingOrders} pending",
                Color = "bg-amber-50", Icon = "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2",
                TextColor = "text-amber-600" },
                new { Label = "This month", Value = "$" + Model.MonthEarnings.ToString("0.00"),
                Sub = "Your earnings",
                Color = "bg-green-50", Icon = "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
                TextColor = "text-green-600" },
                new { Label = "Total earnings", Value = "$" + Model.TotalEarnings.ToString("0.00"),
                Sub = "All time",
                Color = "bg-purple-50", Icon = "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
                TextColor = "text-purple-600" }
                })
        {
            <div class="bg-white rounded-2xl border border-gray-100
                            shadow-sm p-5">
                <div class="w-10 h-10 @stat.Color rounded-xl flex items-center
                                justify-center mb-3">
                    <svg class="w-5 h-5 @stat.TextColor" fill="none"
                         stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              stroke-width="1.5" d="@stat.Icon" />
                    </svg>
                </div>
                <p class="text-2xl font-bold text-gray-900">@stat.Value</p>
                <p class="text-sm text-gray-500 mt-0.5">@stat.Label</p>
                <p class="text-xs text-gray-400 mt-1">@stat.Sub</p>
            </div>
        }
    </div>
    <!-- Quick links + Recent orders -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Quick actions -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h2 class="font-bold text-gray-900 mb-4">Quick actions</h2>
            <div class="space-y-2">
                <a href="/vendor/products/create"
                   class="flex items-center gap-3 p-3 rounded-xl
                          hover:bg-gray-50 transition-colors">
                    <div class="w-8 h-8 bg-primary-100 rounded-lg flex
                                items-center justify-center">
                        <svg class="w-4 h-4 text-primary-600" fill="none"
                             stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                    </div>
                    <span class="text-sm font-medium text-gray-700">
                        Add new product
                    </span>
                </a>
                <a href="/vendor/products"
                   class="flex items-center gap-3 p-3 rounded-xl
                          hover:bg-gray-50 transition-colors">
                    <div class="w-8 h-8 bg-amber-100 rounded-lg flex
                                items-center justify-center">
                        <svg class="w-4 h-4 text-amber-600" fill="none"
                             stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  stroke-width="2"
                                  d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                    </div>
                    <span class="text-sm font-medium text-gray-700">
                        My products
                    </span>
                </a>
                <a href="/vendor/orders"
                   class="flex items-center gap-3 p-3 rounded-xl
                          hover:bg-gray-50 transition-colors">
                    <div class="w-8 h-8 bg-green-100 rounded-lg flex
                                items-center justify-center">
                        <svg class="w-4 h-4 text-green-600" fill="none"
                             stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  stroke-width="2"
                                  d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                        </svg>
                    </div>
                    <span class="text-sm font-medium text-gray-700">
                        My orders
                    </span>
                </a>
            </div>
        </div>

        <!-- Recent orders -->
        <div class="lg:col-span-2 bg-white rounded-2xl border border-gray-100
                    shadow-sm p-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="font-bold text-gray-900">Recent orders</h2>
                <a href="/vendor/orders"
                   class="text-xs text-primary-600 hover:underline">
                    View all
                </a>
            </div>

            @if (!Model.RecentOrders.Any())
            {
                <p class="text-sm text-gray-500 text-center py-8">
                    No orders yet
                </p>
            }
            else
            {
                <div class="space-y-3">
                    @foreach (var order in Model.RecentOrders)
                    {
                        <a href="/vendor/orders/@order.OrderId"
                           class="flex items-center justify-between p-3
                                          rounded-xl hover:bg-gray-50 transition-colors">
                            <div>
                                <p class="text-sm font-medium text-gray-900">
                                    @order.OrderNumber
                                </p>
                                <p class="text-xs text-gray-500">
                                    @order.CustomerName ·
                                    @order.CreatedAt.ToString("MMM dd")
                                </p>
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="text-xs font-medium px-2 py-1
                                                     rounded-full @order.StatusColor">
                                    @order.Status
                                </span>
                                <span class="text-sm font-bold text-gray-900">
                                    $@order.Earnings.ToString("0.00")
                                </span>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>

