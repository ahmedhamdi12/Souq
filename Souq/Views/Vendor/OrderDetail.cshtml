@model Souq.ViewModels.Orders.OrderDetailViewModel
@{
    ViewData["Title"] = "Order " + Model.OrderNumber;
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Header -->
    <div class="flex items-center gap-4 mb-8">
        <a href="/vendor/orders"
           class="p-2 rounded-lg hover:bg-gray-100 transition-colors">
            <svg class="w-5 h-5 text-gray-600" fill="none"
                 stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                      stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
        </a>
        <div class="flex-1">
            <div class="flex items-center justify-between flex-wrap gap-4">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">
                        @Model.OrderNumber
                    </h1>
                    <div class="flex items-center gap-2 mt-1">
                        <p class="text-sm text-gray-500">
                            @Model.CreatedAt.ToString("MMMM dd, yyyy")
                        </p>
                        <span class="text-xs font-medium px-2.5 py-1
                                     rounded-full @Model.StatusColor">
                            @Model.Status
                        </span>
                    </div>
                </div>

                <!-- Status update dropdown -->
                @if (Model.CanUpdateStatus)
                {
                    <div x-data="{ open: false }" class="relative">
                        <button @@click="open = !open"
                                class="flex items-center gap-2 bg-primary-600
                                           hover:bg-primary-700 text-white text-sm
                                           font-medium px-4 py-2 rounded-xl
                                           transition-colors">
                            Update status
                            <svg class="w-4 h-4" fill="none"
                                 stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </button>

                        <div x-show="open"
                             @@click.away="open = false"
                             x-transition
                             class="absolute right-0 mt-2 w-48 bg-white
                                        rounded-xl shadow-lg border border-gray-100
                                        py-1 z-50">
                            @foreach (var status in
                                                    Model.AvailableStatusTransitions)
                            {
                                <button onclick="updateStatus('@status')"
                                        class="w-full text-left px-4 py-2
                                                       text-sm text-gray-700
                                                       hover:bg-gray-50 transition-colors">
                                    Mark as @status
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- ── Items ── -->
        <div class="lg:col-span-2 space-y-5">
            <div class="bg-white rounded-2xl border border-gray-100
                        shadow-sm p-6">
                <h2 class="font-bold text-gray-900 mb-5">Your items</h2>
                <div class="space-y-4">
                    @foreach (var item in Model.Items)
                    {
                        <div class="flex gap-4 items-start pb-4
                                        border-b border-gray-100 last:border-0
                                        last:pb-0">
                            <div class="w-16 h-16 rounded-xl overflow-hidden
                                            bg-gray-50 flex-shrink-0">
                                @if (item.ImageUrl != null)
                                {
                                    <img src="@item.ImageUrl"
                                         alt="@item.ProductName"
                                         class="w-full h-full object-cover" />
                                }
                            </div>
                            <div class="flex-1">
                                <p class="font-medium text-gray-900 text-sm">
                                    @item.ProductName
                                </p>
                                <p class="text-xs text-gray-500 mt-0.5">
                                    @item.VariationName
                                </p>
                                <p class="text-xs text-gray-500 mt-0.5">
                                    Qty: @item.Quantity
                                    × $@item.UnitPrice.ToString("0.00")
                                </p>
                            </div>
                            <div class="text-right">
                                <p class="font-bold text-gray-900 text-sm">
                                    $@item.LineTotal.ToString("0.00")
                                </p>
                                <p class="text-xs text-green-600 mt-0.5">
                                    Earn $@item.VendorEarnings.ToString("0.00")
                                </p>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <!-- Shipping -->
            <div class="bg-white rounded-2xl border border-gray-100
                        shadow-sm p-6">
                <h2 class="font-bold text-gray-900 mb-4">
                    Ship to
                </h2>
                <div class="text-sm text-gray-600 space-y-1">
                    <p class="font-medium text-gray-900">
                        @Model.ShippingFullName
                    </p>
                    <p>@Model.ShippingAddress</p>
                    <p>@Model.ShippingCity, @Model.ShippingCountry</p>
                    <p>@Model.ShippingPhone</p>
                </div>
            </div>
        </div>
        <!-- ── Earnings Summary ── -->
        <div class="lg:col-span-1">
            <div class="bg-white rounded-2xl border border-gray-100
                        shadow-sm p-6 sticky top-24">

                <h2 class="font-bold text-gray-900 mb-4">
                    Your earnings
                </h2>

                <div class="space-y-2 text-sm">
                    <div class="flex justify-between text-gray-600">
                        <span>Items subtotal</span>
                        <span>$@Model.SubTotal.ToString("0.00")</span>
                    </div>
                    <div class="flex justify-between text-gray-600">
                        <span>Platform fee (5%)</span>
                        <span class="text-red-500">
                            -$@((Model.SubTotal - Model.VendorEarnings)
                                                        .ToString("0.00"))
                        </span>
                    </div>
                    <div class="flex justify-between font-bold text-green-700
                                pt-3 border-t border-gray-100 text-base">
                        <span>Your earnings</span>
                        <span>$@Model.VendorEarnings.ToString("0.00")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        debugger;
        async function updateStatus(newStatus) {
            const confirmed = confirm(
                `Are you sure you want to mark this order as ${newStatus}?`);
            if (!confirmed) return;

            const res = await fetch('/vendor/orders/update-status', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector(
                        'input[name="__RequestVerificationToken"]')?.value ?? ''
                },
                body: JSON.stringify({
                    orderId:   @Model.OrderId,
                    newStatus: newStatus
                })
            });

            const data = await res.json();
            if (data.success) {
                window.location.reload();
            } else {
                alert('Failed to update status. Please try again.');
            }
        }
    </script>
    <form id="af-form">@Html.AntiForgeryToken()</form>
}

